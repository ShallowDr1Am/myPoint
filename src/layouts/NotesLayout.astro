---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        --primary: #0070cc;
        --bg: #ffffff;
        --text: #333333;
        --border: #eeeeee;
        --code-bg: #f4f4f4;
        --pre-bg: #1e1e1e;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg);
      }
      nav {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }
      nav a {
        color: var(--primary);
        text-decoration: none;
        font-size: 0.95rem;
      }
      nav a:hover { text-decoration: underline; }
      h1 {
        font-size: 1.8rem;
        border-bottom: 2px solid var(--border);
        padding-bottom: 0.75rem;
        margin-bottom: 1.5rem;
      }
      h2 {
        font-size: 1.4rem;
        margin-top: 2.5rem;
        color: #1a1a1a;
        border-left: 4px solid var(--primary);
        padding-left: 0.75rem;
      }
      h3 { font-size: 1.15rem; margin-top: 1.5rem; color: #444; }
      p { margin: 1rem 0; }
      ul, ol { padding-left: 1.5rem; }
      li { margin: 0.5rem 0; }
      code {
        background: var(--code-bg);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.88em;
        font-family: 'SF Mono', Consolas, monospace;
      }
      pre {
        background: var(--pre-bg);
        padding: 1.25rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.25rem 0;
      }
      pre code {
        background: none;
        padding: 0;
        color: #e1e4e8;
        font-size: 0.9rem;
      }
      blockquote {
        border-left: 4px solid #ffd700;
        background: #fffbea;
        padding: 0.75rem 1rem;
        margin: 1rem 0;
        border-radius: 0 4px 4px 0;
      }
      table {
        border-collapse: collapse;
        width: 100%;
        margin: 1rem 0;
      }
      th, td {
        border: 1px solid #ddd;
        padding: 0.75rem;
        text-align: left;
      }
      th { background: #f8f8f8; font-weight: 600; }
      a { color: var(--primary); }
      a:hover { text-decoration: underline; }
      strong { color: #c00; }
      hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
      img { max-width: 100%; border-radius: 8px; }
    </style>
  </head>
  <body>
    <nav><a href="/">← 返回首页</a></nav>
    <main>
      <slot />
    </main>
  </body>
</html>
