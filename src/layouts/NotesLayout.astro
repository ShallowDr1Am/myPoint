---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <main class="mx-auto min-h-screen w-full max-w-4xl px-6 py-8 sm:px-8 sm:py-10">
      <nav class="mb-8">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-cyan-700 shadow-sm transition hover:border-cyan-300 hover:bg-cyan-50"
        >
          <span>←</span>
          <span>返回首页</span>
        </a>
      </nav>

      <article
        class="prose prose-slate max-w-none rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_24px_80px_-48px_rgba(15,23,42,0.4)] sm:p-10"
      >
        <slot />
      </article>
    </main>
  </body>
</html>
