---
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
notes.sort((a, b) => a.id.localeCompare(b.id));
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>我的笔记</title>
    <style>
      :root {
        --primary: #0070cc;
        --bg: #ffffff;
        --text: #333333;
        --card-bg: #f8f9fa;
        --border: #e0e0e0;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif;
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg);
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--border);
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
      }
      a.card {
        display: block;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.25rem;
        text-decoration: none;
        color: var(--text);
        transition: all 0.2s ease;
      }
      a.card:hover {
        border-color: var(--primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 112, 204, 0.15);
      }
      .card-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--primary);
        margin-bottom: 0.5rem;
      }
      .card-path {
        font-size: 0.85rem;
        color: #888;
        font-family: 'SF Mono', Consolas, monospace;
      }
    </style>
  </head>
  <body>
    <h1>📚 我的笔记</h1>
    <div class="grid">
      {notes.map((note) => (
        <a href={`/${note.id}/`} class="card">
          <div class="card-title">{note.data.title || note.id}</div>
          <div class="card-path">{note.id}.md</div>
        </a>
      ))}
    </div>
  </body>
</html>
