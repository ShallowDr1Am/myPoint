---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const notes = await getCollection('notes');
notes.sort((a, b) => a.id.localeCompare(b.id));
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>我的笔记</title>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <main class="mx-auto min-h-screen w-full max-w-6xl px-6 py-10 sm:px-8 lg:px-10">
      <section class="mb-10 rounded-[2rem] border border-slate-200 bg-linear-to-br from-white via-sky-50 to-cyan-100 p-8 shadow-[0_24px_80px_-48px_rgba(14,116,144,0.45)] sm:p-10">
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.35em] text-cyan-700">Dimensional Disk</p>
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl">
            <h1 class="text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">我的前端笔记库</h1>
            <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">
              把零散的知识点整理成可浏览、可回看的卡片，方便持续沉淀 CSS、浏览器和工程化相关内容。
            </p>
          </div>
          <div class="grid grid-cols-2 gap-3 text-sm text-slate-600">
            <div class="rounded-2xl border border-white/70 bg-white/80 px-4 py-3 backdrop-blur">
              <div class="text-2xl font-bold text-slate-900">{notes.length}</div>
              <div>篇笔记</div>
            </div>
            <div class="rounded-2xl border border-white/70 bg-white/80 px-4 py-3 backdrop-blur">
              <div class="text-2xl font-bold text-slate-900">Astro</div>
              <div>静态站点</div>
            </div>
          </div>
        </div>
      </section>

      <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {notes.map((note) => (
          <a
            href={`/${note.id}/`}
            class="group rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-[0_18px_50px_-35px_rgba(15,23,42,0.45)] transition duration-200 hover:-translate-y-1 hover:border-cyan-300 hover:shadow-[0_28px_70px_-35px_rgba(8,145,178,0.4)]"
          >
            <div class="mb-6 inline-flex rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-700">
              Note
            </div>
            <h2 class="text-xl font-bold tracking-tight text-slate-900 transition group-hover:text-cyan-700">
              {note.data.title || note.id}
            </h2>
            <p class="mt-3 break-all font-mono text-sm text-slate-500">{note.id}.md</p>
            <div class="mt-8 flex items-center justify-between text-sm font-medium text-slate-500">
              <span>查看详情</span>
              <span class="text-cyan-700 transition group-hover:translate-x-1">→</span>
            </div>
          </a>
        ))}
      </section>
    </main>
  </body>
</html>
